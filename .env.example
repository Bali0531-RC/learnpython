NEXT_PUBLIC_APP_URL=http://localhost:3000
JUDGE_API_URL=http://127.0.0.1:8001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erettsegi
REDIS_URL=redis://127.0.0.1:6379

# Optional Docker Compose overrides. If omitted, docker-compose.yml uses the
# internal service names automatically.
# DOCKER_JUDGE_API_URL=http://judge:8000
# DOCKER_DATABASE_URL=postgresql://postgres:postgres@db:5432/erettsegi
# DOCKER_REDIS_URL=redis://redis:6379

# Optional: enables AI code review in the workspace UI.
OPENAI_API_KEY=
OPENAI_REVIEW_MODEL=gpt-5-nano
AI_REVIEW_GLOBAL_TOKEN_LIMIT=2000000
AI_REVIEW_GLOBAL_TOKEN_WINDOW_SECONDS=86400